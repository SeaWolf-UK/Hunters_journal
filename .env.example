# ElevenLabs API credentials (server-side only, never exposed to client)
# Optional — the app works without it, but the skull won't speak aloud.
# Get a key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=TxGEqnHWrfWFTfGW9XeX

# Ollama local LLM config (for AI-powered creature identification)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-v4-pro:cloud

# Server port
PORT=3001
